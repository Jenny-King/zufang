.detail-page {
  padding-bottom: 140rpx;
}

.error-box {
  padding: 20rpx;
  border-radius: 8rpx;
  color: #ff4d4f;
  background: #fff1f0;
  font-size: 24rpx;
}

.detail-card {
  overflow: hidden;
}

.image-swiper {
  width: 100%;
  height: 440rpx;
  background: #f5f5f5;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.main-info {
  padding: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f1f1f;
}

.price {
  margin-top: 10rpx;
  font-size: 34rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.meta-row {
  margin-top: 12rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meta-item {
  background: #e6f4ff;
  color: #1677ff;
  padding: 6rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.address {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #666666;
}

.section {
  padding: 0 24rpx 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.section-content {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.facility-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.facility-item {
  font-size: 22rpx;
  color: #1677ff;
  background: #f0f7ff;
  border-radius: 4rpx;
  padding: 6rpx 10rpx;
}

.facility-empty {
  color: #999999;
  font-size: 24rpx;
}

.address-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888);
  padding: 12rpx 0;
}

.nearby-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.nearby-title {
  font-size: 28rpx;
}

.nearby-distance {
  font-size: 24rpx;
  color: #999;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
  background: #ffffff;
  border-top: 2rpx solid #f0f0f0;
}

.bottom-btn {
  flex: 1;
  margin: 0;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.bottom-btn.ghost {
  background: #ffffff;
  border: 2rpx solid #1677ff;
  color: #1677ff;
}

.bottom-btn.primary {
  background: #1677ff;
  color: #ffffff;
}
