@import "../../styles/variables.wxss";

.publish-page {
  min-height: 100vh;
  background: var(--color-background-page);
}

.publish-shell {
  display: flex;
  flex-direction: column;
  gap: var(--section-gap);
}

.publish-hero {
  padding: var(--card-padding);
}

.form-title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
  transition: all var(--duration-fast) var(--easing-standard);
}

.form-title.active {
  padding: var(--space-lg) var(--space-md);
  border-radius: var(--radius-lg);
  background: var(--color-info-bg);
  color: var(--color-info);
  box-shadow: var(--shadow-focus);
}

.step-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.stepper-wrap {
  margin-top: var(--space-md);
}

.loading-panel {
  padding: var(--card-padding);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  border-radius: var(--radius-lg);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

.form-card {
  padding: var(--card-padding);
  margin-bottom: var(--section-gap);
}

.section-title {
  margin-bottom: var(--space-sm);
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-heavy);
}

.form-row {
  padding-top: var(--space-md);
  padding-bottom: var(--space-md);
  border-bottom: var(--line-width-hairline) solid var(--color-border);
}

.form-card .form-row:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.label {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-1);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
}

.helper-text {
  color: var(--color-text-3);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.input,
.textarea,
.layout-picker,
.meta-tag-control {
  box-sizing: border-box;
  width: 100%;
  background: var(--color-background-card);
}

.input {
  min-height: var(--input-height);
  padding: 0 var(--space-md);
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-text-1);
  font-size: var(--font-md);
}

.layout-picker-row {
  display: flex;
  gap: var(--space-xs);
}

.layout-picker {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: var(--input-height);
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-sm);
}

.meta-tag,
.location-panel,
.submit-preview {
  padding: var(--space-md);
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--gradient-panel);
}

.meta-tag-label {
  display: block;
  margin-bottom: var(--space-sm);
  color: var(--color-text-2);
  font-size: var(--font-caption);
}

.meta-tag-control {
  min-height: 68rpx;
  border-radius: var(--radius-md);
}

.meta-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-1);
}

.location-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  border-radius: var(--radius-md);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
}

.location-btn::after {
  border: none;
}

.location-address {
  margin-top: var(--space-sm);
}

.location-map {
  width: 100%;
  height: 260rpx;
  margin-top: var(--space-sm);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.textarea {
  min-height: 220rpx;
  padding: var(--space-md);
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-text-1);
  font-size: var(--font-md);
}

.facility-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.facility-tag {
  box-sizing: border-box;
  width: calc((100% - var(--space-lg)) / 3);
  min-height: 72rpx;
  padding: 0 var(--space-xs);
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-background-card);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: 68rpx;
  text-align: center;
}

.facility-tag.active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  box-shadow: var(--shadow-focus);
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.image-grid-top {
  margin-top: var(--space-3xs);
}

.image-item {
  position: relative;
  width: var(--image-upload-size);
  height: var(--image-upload-size);
}

.preview-image {
  width: 100%;
}

.upload-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--overlay-bg);
}

.upload-overlay__progress {
  color: var(--color-text-inverse);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.remove-btn {
  position: absolute;
  top: calc(var(--space-xs) * -1);
  right: calc(var(--space-xs) * -1);
  width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: var(--radius-pill);
  background: var(--color-danger);
  color: var(--color-text-inverse);
  font-size: var(--font-xs);
  text-align: center;
}

.image-add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: var(--image-upload-size);
  height: var(--image-upload-size);
  border: var(--line-width-thin) dashed var(--color-border-strong);
  border-radius: var(--radius-md);
  background: var(--color-background-card);
  color: var(--color-text-3);
  font-size: var(--font-label);
}

.submit-preview {
  border: none;
}

.submit-preview-title {
  color: var(--color-primary-dark);
  font-size: var(--font-label);
  font-weight: var(--weight-heavy);
}

.submit-preview-subtitle {
  margin-top: var(--space-2xs);
  color: var(--color-primary);
  font-size: var(--font-caption);
  line-height: var(--lh-normal);
}

.step-actions {
  display: flex;
  gap: var(--space-sm);
}

.step-btn {
  flex: 1;
  height: var(--button-height);
  line-height: var(--button-height);
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
}

.step-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.step-btn.secondary {
  background: var(--color-background-subtle);
  color: var(--color-text-2);
}
