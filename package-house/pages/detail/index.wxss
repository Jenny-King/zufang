@import "../../../styles/variables.wxss";

.detail-page {
  padding-bottom: calc(var(--bottom-bar-height) + env(safe-area-inset-bottom));
  background: var(--color-background-page);
}

.detail-loading {
  padding: var(--card-padding);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  border-radius: var(--radius-sm);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

.detail-card {
  overflow: hidden;
}

.gallery-wrap {
  position: relative;
}

.image-swiper {
  width: 100%;
  height: 440rpx;
  background: var(--color-background-subtle);
}

.swiper-item,
.swiper-image {
  width: 100%;
}

.gallery-counter {
  position: absolute;
  right: var(--space-md);
  bottom: var(--space-md);
  padding: var(--space-3xs) var(--space-sm);
  border-radius: var(--radius-pill);
  background: var(--toast-bg);
  color: var(--toast-text);
  font-size: var(--font-caption);
}

.main-info {
  padding: var(--card-padding);
}

.title {
  color: var(--color-text-1);
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
}

.price {
  margin-top: var(--space-2xs);
  color: var(--color-danger);
  font-size: var(--font-xl);
  font-weight: var(--weight-bold);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-xs);
}

.meta-item {
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-xs);
  background: var(--color-info-bg);
  color: var(--color-info);
  font-size: var(--font-caption);
}

.address {
  margin-top: var(--space-sm);
  color: var(--color-text-2);
  font-size: var(--font-sm);
}

.section {
  padding: 0 var(--card-padding) var(--card-padding);
}

.section-title {
  margin-bottom: var(--space-2xs);
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-medium);
}

.section-content,
.address-text {
  color: var(--color-text-2);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.detail-map {
  width: 100%;
  height: 300rpx;
}

.facility-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
}

.facility-item {
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-xs);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-caption);
}

.nearby-item {
  display: flex;
  justify-content: space-between;
  padding: var(--space-sm) 0;
  border-bottom: var(--line-width-hairline) solid var(--color-background-subtle);
}

.nearby-title {
  color: var(--color-text-1);
  font-size: var(--font-md);
}

.nearby-distance {
  color: var(--color-text-3);
  font-size: var(--font-sm);
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--page-padding);
  padding-bottom: calc(var(--space-md) + env(safe-area-inset-bottom));
  background: var(--color-background-card);
  border-top: var(--line-width-thin) solid var(--color-background-subtle);
}

.bottom-btn {
  flex: 1;
  height: var(--action-bar-button-height);
  line-height: var(--action-bar-button-height);
  margin: 0;
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
}

.bottom-btn.ghost {
  background: var(--color-background-card);
  border: var(--line-width-thin) solid var(--color-primary);
  color: var(--color-primary);
}

.bottom-btn.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}
