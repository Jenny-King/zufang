@import "../../styles/variables.wxss";

.home-page {
  min-height: 100vh;
  background: var(--color-background-page);
}

.home-top-bar {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 10;
  padding: 0 var(--page-padding) var(--space-lg);
  background: var(--color-background-page);
}

.home-scroll {
  height: 100vh;
}

.home-content {
  padding: 0 var(--page-padding) calc(var(--space-3xl) + env(safe-area-inset-bottom));
}

.search-panel {
  padding: var(--space-md);
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card);
}

.search-capsule {
  display: flex;
  align-items: center;
  min-height: var(--fab-size);
  overflow: hidden;
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-pill);
  background: var(--skeleton-highlight-color);
}

.search-capsule-city {
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  flex-shrink: 0;
  max-width: 190rpx;
  min-height: var(--fab-size);
  padding: 0 var(--space-md);
  border-right: var(--line-width-thin) solid var(--color-border);
}

.city-dot {
  width: 14rpx;
  height: 14rpx;
  flex-shrink: 0;
  border-radius: var(--radius-pill);
  background: var(--color-success);
  box-shadow: 0 0 0 var(--space-3xs) var(--color-success-bg);
}

.search-capsule-city-label {
  max-width: 132rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
  color: var(--color-text-2);
}

.city-entry-arrow,
.filter-chip-arrow {
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.search-capsule-input {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  padding: 0 var(--space-sm);
}

.search-capsule-icon {
  flex-shrink: 0;
  color: var(--color-text-3);
  font-size: var(--font-sm);
}

.search-input {
  flex: 1;
  min-height: var(--fab-size);
  font-size: var(--font-sm);
  color: var(--color-text-1);
}

.search-submit-btn {
  width: 124rpx;
  min-height: var(--fab-size);
  line-height: var(--fab-size);
  margin: 0;
  padding: 0;
  border-radius: 0 var(--radius-pill) var(--radius-pill) 0;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-label);
  font-weight: var(--weight-bold);
}

.search-submit-btn::after {
  border: none;
}

.filter-bar {
  display: flex;
  width: 100%;
  margin-top: var(--space-lg);
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2xs);
  min-height: 64rpx;
  margin-right: var(--space-xs);
  padding: 0 var(--space-lg);
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-text-2);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
}

.filter-chip-active {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.filter-chip-active .filter-chip-arrow {
  color: var(--color-text-inverse);
}

.filter-reset-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  min-height: 64rpx;
  margin: 0;
  padding: 0 var(--space-lg);
  border-radius: var(--radius-pill);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.filter-reset-btn::after {
  border: none;
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  padding: var(--card-padding);
  margin-top: var(--space-lg);
  border-radius: var(--radius-lg);
  background: var(--color-danger-bg);
}

.error-box__text {
  flex: 1;
  color: var(--color-danger);
  font-size: var(--font-sm);
  line-height: var(--lh-normal);
}

.error-box__retry {
  min-width: 120rpx;
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
  font-weight: var(--weight-bold);
}

.error-box__retry::after {
  border: none;
}

.content-section,
.latest-section {
  margin-top: var(--space-lg);
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-2xs) 0 var(--space-lg);
}

.section-heading-title {
  color: var(--color-text-1);
  font-size: var(--font-title-sm);
  font-weight: var(--weight-heavy);
}

.section-heading-link,
.section-heading-count {
  color: var(--color-text-3);
  font-size: var(--font-caption);
}

.featured-row {
  display: flex;
  width: 100%;
  white-space: nowrap;
  padding-bottom: var(--space-3xs);
}

.featured-card {
  display: inline-block;
  width: 308rpx;
  margin-right: var(--space-lg);
  border-radius: var(--radius-2xl);
  overflow: hidden;
  background: var(--color-background-card);
  box-shadow: var(--shadow-card);
  vertical-align: top;
}

.featured-thumb-wrap,
.latest-card-thumb-wrap {
  position: relative;
  overflow: hidden;
}

.featured-thumb-wrap {
  padding: var(--space-sm);
}

.featured-thumb,
.latest-card-thumb {
  display: block;
  width: 100%;
}

.accent-blue {
  background: var(--color-primary-bg);
}

.accent-green {
  background: var(--color-accent-green-bg);
}

.accent-gold {
  background: var(--color-accent-amber-bg);
}

.accent-pink {
  background: var(--color-accent-rose-bg);
}

.accent-purple {
  background: var(--color-accent-purple-bg);
}

.featured-badge {
  position: absolute;
  left: var(--space-lg);
  top: var(--space-lg);
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-pill);
  color: var(--color-text-inverse);
  font-size: var(--font-xs);
  font-weight: var(--weight-bold);
}

.featured-badge-red {
  background: var(--color-danger);
}

.featured-badge-blue {
  background: var(--color-primary);
}

.featured-badge-green {
  background: var(--color-success);
}

.featured-body {
  padding: 0 var(--card-padding) var(--card-padding);
}

.featured-price,
.latest-card-price {
  display: flex;
  align-items: flex-end;
  gap: var(--space-2xs);
}

.featured-price-main,
.latest-card-price-main {
  color: var(--color-primary);
  font-size: var(--font-xl);
  font-weight: var(--weight-heavy);
}

.featured-price-unit,
.latest-card-price-unit {
  padding-bottom: var(--space-3xs);
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.featured-title {
  margin-top: var(--space-2xs);
  color: var(--color-text-1);
  font-size: var(--font-sm);
  font-weight: var(--weight-bold);
}

.featured-tags,
.latest-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2xs);
  margin-top: var(--space-xs);
}

.featured-tag,
.latest-card-tag {
  padding: var(--space-3xs) var(--space-xs);
  border-radius: var(--radius-sm);
  background: var(--color-background-subtle);
  color: var(--color-text-2);
  font-size: var(--font-xs);
  line-height: var(--lh-normal);
}

.featured-tag-highlight,
.latest-card-tag-highlight {
  background: var(--color-accent-green-bg);
  color: var(--color-accent-green);
}

.divider {
  height: var(--space-xs);
  margin-top: var(--space-lg);
  background: var(--color-background-muted);
}

.latest-heading {
  padding-top: var(--space-lg);
}

.sort-row {
  display: flex;
  align-items: center;
  padding: var(--space-2xs);
  border-radius: var(--radius-lg);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card);
}

.sort-tab {
  flex: 1;
  padding: var(--space-sm) 0;
  border-radius: var(--radius-md);
  text-align: center;
  color: var(--color-text-3);
  font-size: var(--font-sm);
  font-weight: var(--weight-medium);
}

.sort-tab-active {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-weight: var(--weight-heavy);
}

.latest-list {
  margin-top: var(--space-lg);
}

.latest-card {
  display: flex;
  gap: var(--space-lg);
  padding: var(--card-padding);
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-2xl);
  background: var(--color-background-card);
  box-shadow: var(--shadow-card);
}

.latest-card-thumb-wrap {
  width: var(--image-thumb-size);
  flex-shrink: 0;
  padding: var(--space-2xs);
  border-radius: var(--radius-lg);
}

.latest-card-body {
  flex: 1;
  min-width: 0;
}

.latest-card-title {
  color: var(--color-text-1);
  font-size: var(--font-md);
  font-weight: var(--weight-bold);
  line-height: var(--lh-snug);
  overflow: hidden;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.latest-card-address {
  margin-top: var(--space-xs);
  color: var(--color-text-3);
  font-size: var(--font-caption);
}

.latest-card-time {
  margin-top: var(--space-2xs);
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.loading-tip {
  padding: var(--space-lg) 0;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  text-align: center;
}
