.publish-page {
  min-height: 100vh;
}

.form-card {
  padding: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #1f1f1f;
  transition: all 0.2s ease;
}

.form-title.active {
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  color: #1677ff;
  background: #eaf3ff;
  box-shadow: 0 18rpx 36rpx rgba(22, 119, 255, 0.14);
}

.form-item {
  margin-bottom: 20rpx;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.meta-tag {
  box-sizing: border-box;
  padding: 18rpx;
  border: 2rpx solid #e6ebf2;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%);
}

.meta-tag-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.meta-tag-control {
  height: 68rpx;
  border-radius: 16rpx;
  border-color: #e8edf3;
  background: #ffffff;
}

.meta-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1f2937;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  color: #333333;
}

.helper-text {
  font-size: 22rpx;
  color: #999999;
}

.input {
  height: 72rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.layout-picker-row {
  display: flex;
  gap: 12rpx;
}

.layout-picker {
  flex: 1;
  text-align: center;
}

.location-panel {
  padding: 20rpx;
  border: 2rpx solid #e6ebf2;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f5f8fc 100%);
}

.location-btn {
  margin: 0;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 24rpx;
}

.location-address {
  margin-top: 12rpx;
}

.facility-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.facility-tag {
  box-sizing: border-box;
  width: calc((100% - 24rpx) / 3);
  min-height: 72rpx;
  padding: 0 12rpx;
  border: 2rpx solid #e6ebf2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 68rpx;
  text-align: center;
}

.facility-tag.active {
  border-color: #1677ff;
  background: #eaf3ff;
  color: #1677ff;
  box-shadow: 0 12rpx 24rpx rgba(22, 119, 255, 0.12);
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 18rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-grid-top {
  margin-top: 6rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background: #f5f5f5;
}

.remove-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #ff4d4f;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  line-height: 36rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #999999;
}

.submit-btn {
  margin-top: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}
