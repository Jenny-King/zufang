.edit-profile-page {
  min-height: 100vh;
}

.form-card {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.input {
  width: 100%;
  height: 76rpx;
  border: 2rpx solid #ececec;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.submit-btn {
  margin-top: 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  background: #1677ff;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.loading-tip {
  text-align: center;
  color: #999999;
  font-size: 24rpx;
  padding-bottom: 20rpx;
}
