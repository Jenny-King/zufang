<view class="container profile-page">
  <view wx:if="{{loading && isLoggedIn && !userInfo}}" class="profile-loading card">
    <skeleton type="profile" />
  </view>

  <view class="card hero-card" wx:if="{{isLoggedIn && userInfo}}">
    <view class="hero-top">
      <view class="hero-main">
        <view class="hero-avatar-wrap" bindtap="onAvatarTap">
          <lazy-image
            class="hero-avatar"
            src="{{userInfo.avatarUrl || '/assets/images/avatar-placeholder.png'}}"
            mode="aspectFill"
            radius="var(--radius-pill)"
            height="108rpx"
          />
          <view class="avatar-mask">{{avatarUploading ? '上传中' : '更换头像'}}</view>
        </view>

        <view class="hero-content">
          <view class="hero-name">{{userInfo.displayName}}</view>
          <view class="hero-subline">{{userInfo.displayPhone}}</view>
        </view>
      </view>
    </view>

    <view class="hero-badges">
      <view class="badge role {{userInfo.roleBadgeClass}}">
        <text>{{userInfo.displayRole}}</text>
      </view>
      <view class="badge identity {{userInfo.identityBadgeClass}}">
        <text class="badge-icon">{{userInfo.identityBadgeIcon}}</text>
        <text>{{userInfo.identityBadgeText}}</text>
      </view>
      <view class="badge wechat {{userInfo.wechatBadgeClass}}">
        <text class="badge-icon badge-dot">{{userInfo.wechatBound ? '●' : '○'}}</text>
        <text>{{userInfo.displayWechatStatus}}</text>
      </view>
    </view>

    <view class="hero-stats">
      <view class="stat-card {{activeQuickAction === 'favorites' ? 'active' : ''}}" data-action="favorites" bindtap="onQuickActionTap">
        <text class="stat-number">{{quickStats.favoriteLabel}}</text>
        <text class="stat-label">我的收藏</text>
      </view>
      <view class="stat-card {{activeQuickAction === 'history' ? 'active' : ''}}" data-action="history" bindtap="onQuickActionTap">
        <text class="stat-number">{{quickStats.historyLabel}}</text>
        <text class="stat-label">浏览历史</text>
      </view>
      <view class="stat-card {{activeQuickAction === 'notifications' ? 'active' : ''}}" data-action="notifications" bindtap="onQuickActionTap">
        <text class="stat-number">{{quickStats.notificationLabel}}</text>
        <text class="stat-label">消息通知</text>
        <text class="stat-badge" wx:if="{{unreadNotificationCount > 0}}">新</text>
      </view>
    </view>
  </view>

  <view class="card guest-card" wx:else>
    <view class="guest-title">未登录</view>
    <view class="guest-subtitle">登录后可查看收藏、历史、通知与个人资料</view>
    <view class="auth-actions">
      <button size="mini" class="auth-btn primary" bindtap="onGoLogin">登录</button>
      <button size="mini" class="auth-btn" bindtap="onGoRegister">注册</button>
    </view>
  </view>

  <view class="section-card" wx:if="{{isLoggedIn && userInfo}}">
    <view class="menu-item" bindtap="onGoSupportCenter">
      <view class="menu-icon amber">
        <text class="menu-icon-text">客</text>
      </view>
      <view class="menu-main">
        <text class="menu-title">客服中心</text>
        <text class="menu-subtitle">常见问题与在线客服</text>
      </view>
      <text class="arrow">></text>
    </view>

    <view class="menu-item" bindtap="onOpenSettingsTap">
      <view class="menu-icon purple">
        <text class="menu-icon-text">设</text>
      </view>
      <view class="menu-main">
        <text class="menu-title">设置</text>
        <text class="menu-subtitle">账号安全与偏好设置</text>
      </view>
      <text class="arrow">></text>
    </view>

    <view class="menu-item" bindtap="onSwitchRoleTap">
      <view class="menu-icon red">
        <text class="menu-icon-text">角</text>
      </view>
      <view class="menu-main">
        <text class="menu-title">切换角色</text>
        <text class="menu-subtitle">租客 / 房东 身份切换</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="account-section" wx:if="{{isLoggedIn}}">
    <view class="account-section-header">
      <text class="account-section-label">已缓存账号</text>
      <text class="account-section-action" bindtap="onSwitchAccountTap">管理</text>
    </view>

    <scroll-view class="account-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="account-inline-list">
        <view
          class="account-inline-item"
          wx:for="{{cachedAccounts}}"
          wx:key="userId"
          data-user-id="{{item.userId}}"
          bindtap="onSelectAccountTap"
        >
          <view class="account-inline-avatar {{item.isActive ? 'active' : ''}}">
            <lazy-image
              class="account-inline-image"
              src="{{item.avatarUrl}}"
              mode="aspectFill"
              radius="var(--radius-pill)"
              height="80rpx"
            />
          </view>
          <text class="account-inline-name {{item.isActive ? 'active' : ''}}">{{item.displayName}}</text>
        </view>

        <view class="account-inline-item" bindtap="onAddAccountTap">
          <view class="account-inline-add">+</view>
          <text class="account-inline-name dim">添加账号</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="logout-wrap" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="onLogoutTap">退出当前账号</button>
  </view>

  <view class="account-switcher-mask" wx:if="{{accountSwitcherVisible}}" bindtap="onCloseAccountSwitcher">
    <view class="account-switcher-panel" catchtap="noop">
      <view class="account-switcher-header">
        <view>
          <view class="account-switcher-title">切换账号</view>
          <view class="account-switcher-subtitle">已缓存的账号可直接切换，无需重复输入登录信息</view>
        </view>
        <view class="tap-area account-switcher-close" bindtap="onCloseAccountSwitcher">×</view>
      </view>

      <view class="account-card-list">
        <view
          class="account-card {{item.isActive ? 'active' : ''}}"
          wx:for="{{cachedAccounts}}"
          wx:key="userId"
          data-user-id="{{item.userId}}"
          bindtap="onSelectAccountTap"
        >
          <view class="account-card-remove" data-user-id="{{item.userId}}" catchtap="onRemoveAccountTap">
            {{removingAccountId === item.userId ? '处理中' : '删除记录'}}
          </view>
          <lazy-image
            class="account-card-avatar"
            src="{{item.avatarUrl}}"
            mode="aspectFill"
            radius="var(--radius-pill)"
            height="92rpx"
          />
          <view class="account-card-main">
            <view class="account-card-title-row">
              <text class="account-card-name">{{item.displayName}}</text>
              <text class="account-card-role">{{item.displayRole}}</text>
            </view>
            <view class="account-card-subline">{{item.displayPhone}}</view>
            <view class="account-card-tags">
              <text class="account-card-tag {{item.isActive ? 'active' : ''}}">{{item.isActive ? '当前账号' : '点击切换'}}</text>
              <text class="account-card-tag">{{item.wechatBound ? '微信已绑定' : '微信未绑定'}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="account-switcher-actions">
        <button class="account-switcher-btn primary" bindtap="onAddAccountTap">添加账号</button>
        <button class="account-switcher-btn" bindtap="onCloseAccountSwitcher">取消</button>
      </view>
    </view>
  </view>
</view>
