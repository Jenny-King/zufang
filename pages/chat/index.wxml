<view class="container chat-page">
  <view wx:if="{{errorText}}" class="error-box">
    <text class="error-box__text">{{errorText}}</text>
    <button class="error-box__retry" bindtap="loadConversationList">重试</button>
  </view>

  <skeleton wx:if="{{listLoading && !conversationList.length}}" type="list-item" count="{{4}}" />

  <empty-state
    wx:elif="{{!listLoading && conversationList.length === 0}}"
    title="暂无会话"
    subtitle="去房源详情联系房东吧"
  />

  <view wx:else class="chat-list">
    <view
      class="chat-item card"
      wx:for="{{conversationList}}"
      wx:key="conversationId"
      data-conversation-id="{{item.conversationId}}"
      data-target-user-id="{{item.targetUserId}}"
      bindtap="onConversationTap"
    >
      <lazy-image
        class="avatar"
        src="{{item.displayAvatar || '/assets/images/avatar-placeholder.png'}}"
        mode="aspectFill"
        radius="var(--radius-pill)"
        height="92rpx"
      />
      <view class="content">
        <view class="top-row">
          <text class="name text-ellipsis">{{item.displayName}}</text>
          <text class="time">{{item.displayLastTime}}</text>
        </view>
        <view class="bottom-row">
          <text class="message text-ellipsis">{{item.displayLastMessage}}</text>
          <text wx:if="{{item.unreadCount > 0}}" class="badge">{{item.unreadCount}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
