@import "../../../styles/variables.wxss";

.chat-detail-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-background-page);
}

.error-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  margin: var(--space-sm) var(--page-padding) 0;
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-danger-bg);
}

.error-box__text {
  color: var(--color-danger);
  font-size: var(--font-sm);
}

.error-box__retry {
  min-height: var(--control-height-sm);
  margin: 0;
  padding: 0 var(--space-md);
  border-radius: var(--radius-pill);
  background: var(--color-background-card);
  color: var(--color-danger);
  font-size: var(--font-caption);
}

.error-box__retry::after {
  border: none;
}

.message-scroll {
  flex: 1;
  box-sizing: border-box;
  padding: var(--space-md) var(--page-padding);
}

.time-divider {
  margin: var(--space-sm) auto;
  color: var(--color-text-3);
  font-size: var(--font-caption);
  text-align: center;
}

.message-row {
  display: flex;
  margin-bottom: var(--space-sm);
}

.message-row.self {
  justify-content: flex-end;
}

.message-row.other {
  justify-content: flex-start;
}

.bubble {
  max-width: 72%;
  padding: var(--space-sm);
  border-radius: var(--radius-sm);
  background: var(--color-background-card);
}

.message-row.self .bubble {
  background: var(--color-info-bg);
}

.content {
  display: block;
  color: var(--color-text-1);
  font-size: var(--font-md);
  line-height: 1.5;
  word-break: break-all;
}

.time {
  display: block;
  margin-top: var(--space-2xs);
  color: var(--color-text-3);
  font-size: var(--font-xs);
}

.input-bar {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-xs) var(--space-sm) calc(var(--space-xs) + env(safe-area-inset-bottom));
  background: var(--color-background-card);
  border-top: var(--line-width-thin) solid var(--color-background-subtle);
}

.msg-input {
  flex: 1;
  min-height: 72rpx;
  padding: 0 var(--space-xs);
  border: var(--line-width-thin) solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-background-card);
  font-size: var(--font-md);
  color: var(--color-text-1);
}

.send-btn {
  min-width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  border-radius: var(--radius-sm);
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-size: var(--font-label);
}
